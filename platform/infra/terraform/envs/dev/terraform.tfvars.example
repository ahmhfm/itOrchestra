# Copy to terraform.tfvars and adjust if needed. Every value has a sensible default, so an empty
# terraform.tfvars (or none at all) works for the standard dev VM.

# kubeconfig_path        = "~/.kube/config"
# kube_context           = ""                      # empty = current-context
