# itOrchestra - editor + dotnet-format conventions (Phase 0.11).
# IMPORTANT: this file declares formatting *preferences* only. It deliberately does NOT raise any
# code-style diagnostic (IDE00xx) to warning/error severity, because an explicit severity here is
# honoured by `dotnet build` and would turn formatting nits (e.g. CRLF vs LF) into build errors.
# Formatting is enforced separately by the advisory `dotnet format --verify-no-changes` CI step.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.{cs,csx}]
indent_size = 4
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false
csharp_using_directive_placement = outside_namespace:silent
csharp_style_namespace_declarations = file_scoped:silent

[*.{yml,yaml,json,proto}]
indent_size = 2

[*.sh]
indent_size = 2

[*.py]
indent_size = 4

[*.md]
trim_trailing_whitespace = false
